---
import BaseLayout from '@layouts/BaseLayout.astro';

const faqCategories = [
  {
    category: '基础概念',
    icon: '💡',
    items: [
      { q: '什么是 Vibe Coding？', a: 'Vibe Coding 就是用自然语言跟 AI 对话来生成代码。你不用写代码，只需要描述你想要什么，AI 帮你写出来。就像请了一个免费的程序员。' },
      { q: '我完全不会编程，能用 Vibe Coding 建网站吗？', a: '完全可以。Vibe Coding 就是为零基础的人设计的。你只需要会打字、会描述需求，剩下的 AI 帮你搞定。' },
      { q: 'Vibe Coding 和传统学编程有什么区别？', a: '传统学编程需要几个月到几年学会写代码；Vibe Coding 让你直接跳过学习阶段，用自然语言指挥 AI 写代码。你是"产品经理"，AI 是"程序员"。' },
      { q: 'AI 生成的代码我要不要看懂？', a: '不需要。你只需要在浏览器里预览效果，觉得满意就行。如果 AI 写错了，截图发给它让它改。' },
      { q: 'Vibe Coding 能做大网站吗？', a: '可以从简单的单页开始，逐步扩展。很多中小型网站（企业官网、个人博客、作品集、电商展示）都可以用 Vibe Coding 完成。大型复杂应用需要更深入的开发知识。' },
    ],
  },
  {
    category: '工具与安装',
    icon: '🔧',
    items: [
      { q: '需要安装什么软件？', a: '最少只需要一个浏览器。推荐安装：VS Code（写代码）、Node.js（运行环境）、GitHub 账号（存代码）、Vercel 账号（部署网站）。所有工具都有免费版。' },
      { q: 'Claude Code 和 Cursor 有什么区别？', a: 'Claude Code 是 Anthropic 的 AI 编程助手，适合在终端中使用，Skills 生态丰富。Cursor 是 AI-native 的代码编辑器，有图形界面，适合习惯 IDE 的用户。两者都能实现 Vibe Coding。' },
      { q: '需要付费吗？', a: '所有核心工具都有免费版：Claude Code 有免费额度、VS Code 免费、GitHub 免费、Vercel 免费部署。只有用量大时才需要付费升级。' },
      { q: 'Mac 和 Windows 有区别吗？', a: '没有本质区别。VS Code、Node.js、GitHub、Vercel 在两大平台都能用。部分 AI 工具在 Windows 上可能需要额外配置。' },
      { q: '手机能 Vibe Coding 吗？', a: '手机浏览器可以查看网站效果，但写代码建议用电脑。不过有些 AI 聊天工具（如 ChatGPT App）可以在手机上帮你生成代码片段。' },
    ],
  },
  {
    category: '开发过程',
    icon: '💻',
    items: [
      { q: 'AI 生成的代码打开是空白的？', a: '检查是否保存为 .html 文件。用浏览器打开（双击文件或右键→打开方式→浏览器），而不是用文本编辑器打开。确保文件名以 .html 结尾。' },
      { q: '图片显示不出来？', a: '图片路径要用相对路径或在线链接。如果图片在本地，确保图片文件和 HTML 文件在同一个文件夹，路径写对了。建议先用在线图片测试。' },
      { q: '样式跟我想要的不一样？', a: '给 AI 更具体的描述。不要说"好看一点"，要说具体的内容：主色用 #2D1B69、字体用 Noto Sans SC、导航栏固定顶部、间距大一点。也可以给 AI 发一个参考网站的链接。' },
      { q: '页面在手机上不好看？', a: '告诉 AI"加响应式设计，适配手机"。如果已经有代码了，说"帮我修复这个页面在手机上的显示问题"。AI 会自动加媒体查询和弹性布局。' },
      { q: '代码太多不知道怎么用？', a: '让 AI 教你。直接问："我是一个小白，请一步一步教我如何把这段代码变成网页"。AI 会给出详细的步骤说明。' },
      { q: 'AI 把我的代码改坏了？', a: '保留之前的版本。每次修改前复制一份完整代码备份。改坏了就回到备份版本，重新告诉 AI 你的需求。建议用 Git 做版本管理。' },
      { q: 'AI 生成的内容是英文的？', a: '在提示词里加一句"请用中文回答"或"请输出中文内容"。大多数 AI 工具会根据你的语言自动适配。' },
      { q: '网站加载速度太慢？', a: '告诉 AI"帮我优化页面加载速度"。常见的优化：压缩图片大小、减少不必要的 JavaScript、使用 CDN 加载库、开启懒加载。' },
      { q: '表单提交后没有反应？', a: '检查表单的 action 地址是否正确。如果用 Formspree，确认表单 ID 是对的。在浏览器控制台（F12→Console）看有没有报错信息。' },
      { q: '导航链接点不了或跳转错误？', a: '检查 href 属性里的文件名是否正确，大小写要一致。确保所有页面文件都在正确的位置。用浏览器右键→检查→Console 看有没有 404 错误。' },
    ],
  },
  {
    category: '部署与上线',
    icon: '🚀',
    items: [
      { q: '怎么让别人访问我的网站？', a: '推荐用 Vercel 部署：注册 Vercel 账号→关联 GitHub 仓库→自动部署。完成后会得到一个 xxx.vercel.app 的链接，发给别人就能访问了。' },
      { q: 'Vercel 部署失败了怎么办？', a: '检查 Vercel 的构建日志（Deploy → Logs），看红色报错信息。最常见的错误：项目框架没选对、入口文件缺失。把报错截图发给 AI 帮你解决。' },
      { q: '可以用自己的域名吗？', a: '可以。在 Vercel 的项目设置中 → Domains → 输入你的域名。需要在域名服务商那里把 DNS 指向 Vercel 的服务器。Vercel 自动处理 HTTPS。' },
      { q: '部署后更新网站怎么做？', a: '修改本地代码 → 保存 → 推送到 GitHub。Vercel 会自动检测到变化并重新部署。整个过程不到 1 分钟。' },
      { q: '免费版 Vercel 够用吗？', a: '对于个人网站、作品集、小型企业官网，免费版完全够用。每月 100GB 带宽、100 小时构建时长，个人使用很难用完。' },
    ],
  },
  {
    category: 'AI 使用技巧',
    icon: '🤖',
    items: [
      { q: '怎么让 AI 给出更好的结果？', a: '提示词越具体，结果越好。不要说"做个网站"，要说"做一个摄影作品展示网站，首页大图全屏，作品集用瀑布流布局，黑白色调"。给 AI 明确的参考方向。' },
      { q: '一次提多个需求好还是一个一个好？', a: '一个需求一个需求地提最好。一次说 10 个需求，AI 容易漏掉或搞混。先做首页，满意了再做作品集页，再添加联系表单，一步步来。' },
      { q: 'AI 生成的代码有 bug 怎么办？', a: '把 bug 截图发给 AI，描述你看到了什么、期望看到什么。AI 会分析代码并修复。常见问题：路径错误、拼写错误、API 调用方式不对。' },
      { q: '可以让 AI 解释它写的代码吗？', a: '可以。直接说"请用大白话解释这段代码是干什么的"。AI 会用通俗的语言逐行解释，帮你理解（即使你不需要理解也能用）。' },
      { q: 'AI 上下文窗口满了怎么办？', a: '开启新对话，把之前生成的完整代码复制进去，然后继续提新需求。建议每次重大改动前保存一个完整版本。' },
    ],
  },
  {
    category: '安全与隐私',
    icon: '🔒',
    items: [
      { q: '把代码给 AI 安全吗？', a: '前端代码（HTML/CSS/JS）通常不涉及敏感信息，可以放心给 AI 看。不要在提示词中放入密码、API 密钥、数据库连接字符串等敏感信息。' },
      { q: '怎么保护网站不被攻击？', a: '小型个人网站不需要太担心安全。基本防护：使用 HTTPS（Vercel 自动提供）、不要在前端代码中硬编码密码、表单添加验证码防止垃圾提交。' },
      { q: 'AI 会盗用我的网站创意吗？', a: '不会。AI 没有记忆功能（除非你主动保存到它的项目里），每次对话都是独立的。你的创意在你的电脑上，AI 只是帮你生成代码。' },
      { q: '要不要备份代码？', a: '强烈建议备份！最简单的备份方式：用 GitHub 管理代码。每次修改后提交（commit）一次，随时可以回到之前的版本。比本地复制粘贴靠谱得多。' },
      { q: '网站被黑了怎么办？', a: '个人网站被黑概率很低。如果真的发生了：1. 从 GitHub 拉取干净的版本重新部署 2. 检查是否在代码中泄露了敏感信息 3. 修改所有相关密码 4. 联系 Vercel 支持。' },
    ],
  },
];

const pitfalls = [
  { title: '先小后大', desc: '从一个页面开始，不要一上来就做 10 个页面。先做首页，满意了再加别的。' },
  { title: '经常保存', desc: '每次 AI 生成新代码后，立即保存文件。浏览器刷新才能看到最新效果。' },
  { title: '一次一个需求', desc: '不要一次性提 10 个修改。先改标题，确认好了再改颜色，再改布局。' },
  { title: '学会回退', desc: '改坏了不要慌。Cmd/Ctrl+Z 撤销，或者从备份文件恢复。' },
  { title: '用浏览器检查', desc: '按 F12 打开开发者工具，Console 看报错，Elements 看 HTML 结构。' },
  { title: '善用截图', desc: '遇到问题截图发给 AI，比用文字描述高效 10 倍。' },
  { title: '注意隐私', desc: '不要把密码、API Key 写在代码里。也不要在提示词中发送敏感信息。' },
  { title: '备份大法', desc: '每次重大改动前，复制整个项目文件夹。有 Git 就用 Git 提交。' },
  { title: '保持简单', desc: '能用一页解决的问题不要做五页。功能越少，bug 越少，上线越快。' },
  { title: '享受过程', desc: '这是创造，不是考试。放松心态，享受用 AI 创造的乐趣。' },
  { title: '先想清楚再动手', desc: '打开 AI 之前，先在纸上想清楚你要什么。想得越清楚，AI 一次做对的概率越高。' },
  { title: '参考优秀网站', desc: '看到喜欢的网站，把链接发给 AI："请参考这个风格帮我做"。比空想要准确得多。' },
  { title: '分阶段验证', desc: '做完一个功能就预览一次，不要等全部做完再检查。早发现，早修复。' },
  { title: '不要完美主义', desc: '第一版做到 80 分就够了，先上线再说。后面可以慢慢优化。' },
  { title: '用 AI 学 AI', desc: '遇到不懂的概念，直接问 AI。把它当成你的私人老师。' },
  { title: '保持对话上下文', desc: '在同一个对话中持续迭代，不要频繁开新对话。AI 会记住之前的修改。' },
  { title: '明确告诉 AI 你的水平', desc: '在提示词开头说"我是一个完全不会编程的小白"。AI 会用更简单的方式回答。' },
  { title: '检查文件扩展名', desc: '保存文件时确保是 .html、.css、.js 后缀，不是 .txt。Windows 默认可能隐藏扩展名。' },
  { title: '使用相对路径', desc: '链接图片或页面时用相对路径（如 images/photo.jpg），不要用绝对路径（如 C:/users/...）。' },
  { title: '手机也要测试', desc: '不要只在电脑上看效果，用手机打开网站看看。Chrome 的 F12 也有手机模拟模式。' },
  { title: '学会看报错信息', desc: '看到红色报错不要慌。复制报错内容发给 AI，它基本都能解决。' },
  { title: '命名要有规律', desc: '文件命名用英文小写+连字符，如 my-portfolio.html。不要用中文或空格。' },
  { title: '不要随意删文件', desc: '不确定一个文件有没有用之前，先移到回收站而不是直接删除。' },
  { title: '优先用 CDN 链接', desc: '引入库（如 Tailwind、Font Awesome）时用 CDN 链接，不需要下载安装。' },
  { title: '每次只改一个文件', desc: '修改时一次只改动一个文件，出问题了容易定位。改完确认没问题再改下一个。' },
  { title: '保持文件夹整洁', desc: '图片放 images/ 文件夹，CSS 放 css/ 文件夹。不要把 30 个文件和代码混在一起。' },
  { title: '了解基本快捷键', desc: 'Ctrl+S 保存、Ctrl+Z 撤销、Ctrl+C/V 复制粘贴、F5 刷新页面。这四个够用 90% 场景。' },
  { title: '不要怕问「蠢」问题', desc: '在编程的世界里，没有蠢问题。每个专家都从小白走过来。遇到不懂的就问 AI。' },
  { title: '记录你的操作步骤', desc: '做了什么修改、用了什么提示词、结果如何——简单记录一下。下次遇到类似问题能快速回忆起来。' },
  { title: '分享你的成果', desc: '网站做好后分享给朋友。获得反馈是进步最快的方式。也欢迎把案例分享到社区。' },
];
---

<BaseLayout title="FAQ / 常见问题" description="Vibe Coding 建站常见问题与解答，30 个常见问题 + 30 条避坑指南">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-3xl lg:text-4xl font-bold mb-3">常见问题</h1>
      <p class="text-[var(--color-text-secondary)] text-lg">遇到问题先看看这里，能解决 90% 的情况</p>
    </div>

    <!-- FAQ by category -->
    <div class="space-y-10">
      {faqCategories.map((cat, ci) => (
        <section class="reveal" style={`transition-delay: ${ci * 80}ms`}>
          <h2 class="flex items-center gap-2 text-xl font-bold mb-4 pb-3 border-b border-[var(--color-border)]">
            <span>{cat.icon}</span>
            <span>{cat.category}</span>
            <span class="ml-auto text-xs font-normal text-[var(--color-text-muted)]">{cat.items.length} 个问题</span>
          </h2>
          <div class="space-y-2.5">
            {cat.items.map((faq, i) => (
              <details class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] open:border-[var(--color-accent)]/30 open:shadow-sm transition-all duration-200 overflow-hidden">
                <summary class="cursor-pointer px-4 py-3.5 font-medium text-[var(--color-text)] group-open:text-[var(--color-accent)] transition-colors flex items-start gap-3 list-none marker:hidden hover:bg-[var(--color-surface-hover)]">
                  <span class="flex-shrink-0 w-6 h-6 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center text-xs font-bold text-[var(--color-accent)] group-open:bg-[var(--color-accent)] group-open:text-white transition-colors">
                    {i + 1}
                  </span>
                  <span class="flex-1 leading-snug">{faq.q}</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0 mt-0.5 text-[var(--color-text-muted)] group-open:rotate-180 transition-transform duration-200">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </summary>
                <div class="px-4 pb-4 pl-14">
                  <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{faq.a}</p>
                </div>
              </details>
            ))}
          </div>
        </section>
      ))}
    </div>

    <!-- Divider -->
    <div class="my-16 flex items-center gap-4">
      <div class="flex-1 h-px bg-[var(--color-border)]"></div>
      <span class="text-sm text-[var(--color-text-muted)] font-medium">🛡️ 避坑指南</span>
      <div class="flex-1 h-px bg-[var(--color-border)]"></div>
    </div>

    <!-- Pitfalls -->
    <div class="reveal">
      <div class="text-center mb-10">
        <h2 class="text-2xl lg:text-3xl font-bold mb-2">🚫 三十条避坑清单</h2>
        <p class="text-[var(--color-text-secondary)]">前人踩过的坑，你就不用再踩了</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {pitfalls.map((item, i) => (
          <div class="group p-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-accent)]/20 hover:shadow-sm transition-all duration-200 flex items-start gap-3">
            <span class="flex-shrink-0 w-7 h-7 rounded-lg bg-gradient-to-br from-[var(--color-accent)]/10 to-[var(--color-brand)]/10 flex items-center justify-center text-xs font-bold text-[var(--color-accent)] group-hover:scale-110 transition-transform">{i + 1}</span>
            <div>
              <strong class="text-sm text-[var(--color-text)]">{item.title}</strong>
              <p class="text-xs text-[var(--color-text-secondary)] mt-0.5 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
