---
// website/src/pages/index.astro
import BaseLayout from '@layouts/BaseLayout.astro';
import PhaseCard from '@components/ui/PhaseCard.astro';
import { PHASES, SITE_DESCRIPTION } from '@lib/constants';
---

<BaseLayout title="首页" description={SITE_DESCRIPTION}>
  <!-- ======== Hero Section ======== -->
  <section class="relative overflow-hidden min-h-[85vh] flex items-center">
    <!-- Animated background orbs -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden -z-10" aria-hidden="true">
      <div class="absolute top-1/4 -left-32 w-96 h-96 rounded-full bg-[var(--color-brand)]/5 blur-3xl animate-float" style="animation-delay: -1s" />
      <div class="absolute bottom-1/4 -right-32 w-[30rem] h-[30rem] rounded-full bg-[var(--color-accent)]/5 blur-3xl animate-float" style="animation-delay: -2s" />
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full bg-[var(--color-brand)]/[0.03] blur-3xl" />
    </div>

    <!-- Decorative grid pattern -->
    <div class="absolute inset-0 pointer-events-none -z-10 opacity-[0.03]" aria-hidden="true"
      style="background-image: linear-gradient(var(--color-brand) 1px, transparent 1px), linear-gradient(90deg, var(--color-brand) 1px, transparent 1px); background-size: 60px 60px;" />

    <div class="w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
      <div class="text-center max-w-3xl mx-auto">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[var(--color-accent)]/10 text-[var(--color-accent)] text-sm font-medium mb-6 animate-fade-in-up">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] animate-pulse" />
          零编程基础也能建站
        </div>

        <!-- Main heading with gradient text -->
        <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-bold leading-[1.15] tracking-tight animate-fade-in-up" style="animation-delay: 100ms">
          <span class="text-[var(--color-text)]">用</span>
          <span class="gradient-text">AI 建网站</span>
          <br />
          <span class="text-[var(--color-text)]">像聊天一样简单</span>
        </h1>

        <p class="mt-6 text-lg lg:text-xl text-[var(--color-text-secondary)] max-w-2xl mx-auto animate-fade-in-up leading-relaxed" style="animation-delay: 200ms">
          {SITE_DESCRIPTION}
        </p>

        <!-- CTA buttons — two distinct paths -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-in-up" style="animation-delay: 300ms">
          <a href="/phases/phase-00" class="group inline-flex items-center justify-center gap-3 px-8 py-4 rounded-xl text-white font-bold text-base tracking-wide transition-all duration-300 shadow-xl hover:shadow-2xl hover:-translate-y-1"
             style="background: linear-gradient(135deg, var(--color-brand) 0%, var(--color-accent-dark) 100%);">
            <span class="text-lg">🚀</span>
            <span>直接上手实战</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-1 transition-transform flex-shrink-0"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="/intro/what-is-vibe-coding" class="group inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text-secondary)] font-medium hover:border-[var(--color-accent)]/30 hover:text-[var(--color-accent)] hover:bg-[var(--color-surface-hover)] transition-all duration-200">
            <span>📖</span>
            先了解什么是 Vibe Coding
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="group-hover:translate-x-0.5 transition-transform"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

        <!-- Stats row -->
        <div class="mt-16 grid grid-cols-3 gap-8 max-w-md mx-auto animate-fade-in-up" style="animation-delay: 400ms">
          <div>
            <div class="text-2xl font-bold gradient-text">9</div>
            <div class="text-xs text-[var(--color-text-muted)] mt-1">实战阶段</div>
          </div>
          <div>
            <div class="text-2xl font-bold gradient-text">30+</div>
            <div class="text-xs text-[var(--color-text-muted)] mt-1">AI Skills</div>
          </div>
          <div>
            <div class="text-2xl font-bold gradient-text">0</div>
            <div class="text-xs text-[var(--color-text-muted)] mt-1">编程基础</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== Phase Timeline ======== -->
  <section class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-2xl lg:text-3xl font-bold">
          <span class="gradient-text">全流程</span>实战路线图
        </h2>
        <p class="mt-3 text-[var(--color-text-secondary)]">9 个阶段，从想法到上线，手把手带你走完</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
        {PHASES.map((phase, i) => (<PhaseCard phase={phase} index={i} href={`/phases/${phase.id}`} />))}
      </div>
    </div>
  </section>

  <!-- ======== Why Vibe Coding ======== -->
  <section class="py-16 lg:py-24 bg-[var(--color-bg-secondary)] relative overflow-hidden">
    <!-- Subtle background -->
    <div class="absolute inset-0 pointer-events-none -z-10" aria-hidden="true">
      <div class="absolute top-0 right-0 w-64 h-64 rounded-full bg-[var(--color-accent)]/[0.03] blur-3xl" />
      <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full bg-[var(--color-brand)]/[0.03] blur-3xl" />
    </div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-2xl lg:text-3xl font-bold">为什么选择 <span class="gradient-text">Vibe Coding</span>？</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="group p-6 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-accent)]/20 hover:shadow-lg transition-all duration-300 reveal reveal-delay-1">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[var(--color-accent)]/10 to-[var(--color-accent)]/5 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300">⏱️</div>
          <h3 class="font-semibold text-lg mb-2">几小时而非几个月</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">传统建站需要数月学习编程，Vibe Coding 让你几小时内从想法到上线。</p>
        </div>
        <div class="group p-6 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-accent)]/20 hover:shadow-lg transition-all duration-300 reveal reveal-delay-2">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[var(--color-accent)]/10 to-[var(--color-accent)]/5 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300">💰</div>
          <h3 class="font-semibold text-lg mb-2">完全免费</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">所有工具都有免费版，Vercel、Netlify 等部署也是免费的。</p>
        </div>
        <div class="group p-6 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-accent)]/20 hover:shadow-lg transition-all duration-300 reveal reveal-delay-3">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[var(--color-accent)]/10 to-[var(--color-accent)]/5 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-300">🎯</div>
          <h3 class="font-semibold text-lg mb-2">无需编程经验</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">用自然语言跟 AI 对话即可，AI 负责写代码，你负责提需求。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== CTA Section ======== -->
  <section class="py-20 lg:py-28 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute inset-0 pointer-events-none -z-10" aria-hidden="true">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--color-brand)]/[0.02] to-transparent" />
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full bg-[var(--color-accent)]/[0.03] blur-3xl" />
    </div>

    <div class="max-w-3xl mx-auto text-center px-4 sm:px-6 lg:px-8 reveal">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[var(--color-accent)]/10 to-[var(--color-brand)]/10 flex items-center justify-center text-3xl mx-auto mb-6">🚀</div>
      <h2 class="text-2xl lg:text-3xl font-bold mb-4">准备好了吗？</h2>
      <p class="text-[var(--color-text-secondary)] mb-8 max-w-lg mx-auto">不需要任何编程基础，现在就开始你的第一个网站。</p>
      <a href="/intro/what-is-vibe-coding" class="group inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-[var(--color-brand)] text-white font-semibold hover:bg-[var(--color-brand-light)] transition-all duration-300 shadow-lg shadow-[var(--color-brand)]/20 hover:shadow-xl hover:shadow-[var(--color-brand)]/30 hover:-translate-y-0.5">
        开始学习
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-1 transition-transform"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>
