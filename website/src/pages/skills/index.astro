---

<BaseLayout title="Skills 索引" description="所有可用的 AI Skills，按类别整理，支持一键安装">
  <div class="flex max-w-7xl mx-auto relative">
    <!-- Main content -->
    <main class="flex-1 min-w-0 px-4 sm:px-6 lg:px-8 py-12 lg:py-16 max-w-3xl mx-auto">
      <h1 class="text-3xl lg:text-4xl font-bold mb-2">Skills 索引</h1>
      <p class="text-[var(--color-text-secondary)] mb-10">所有 AI Skills，按类别整理。点击 📋 复制安装命令。</p>

      {skills.map((category, ci) => (
        <div class="mb-10 reveal" style={`transition-delay: ${ci * 80}ms`}>
          <h2 id={`skill-cat-${ci}`} class="text-xl font-bold mb-4 flex items-center gap-2">
            <span>{category.category}</span>
            <span class="text-sm font-normal text-[var(--color-text-muted)]">({category.items.length})</span>
          </h2>
        <div class="space-y-3">
          {category.items.map((skill) => (
            <div class="p-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-accent)]/20 hover:shadow-md transition-all duration-200">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-semibold text-[var(--color-text)]">{skill.name}</h3>
                  <div class="mt-1.5 space-y-1 text-sm leading-relaxed text-[var(--color-text-secondary)]">
                    <div><span class="inline-block w-12 text-xs font-semibold text-[var(--color-accent)] shrink-0">作用：</span>{skill.desc.purpose}</div>
                    <div><span class="inline-block w-12 text-xs font-semibold text-[var(--color-accent)] shrink-0">用法：</span>{skill.desc.usage}</div>
                    <div><span class="inline-block w-12 text-xs font-semibold text-[var(--color-accent)] shrink-0">场景：</span>{skill.desc.scenario}</div>
                  </div>
                </div>
              </div>
              <div class="mt-3 flex items-center gap-2">
                <code class="text-xs px-3 py-1.5 rounded-lg bg-[var(--color-bg-secondary)] text-[var(--color-text)] flex-1 overflow-x-auto font-mono">{skill.install}</code>
                <button
                  class="skill-copy-btn flex-shrink-0 w-7 h-7 rounded-md border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-xs hover:bg-[var(--color-accent)] hover:text-white hover:border-[var(--color-accent)] transition-all duration-200 flex items-center justify-center"
                  data-copy={skill.install}
                  title="复制安装命令"
                >📋</button>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}

    <div class="mt-10 reveal p-5 rounded-xl bg-gradient-to-br from-[var(--color-bg-secondary)] to-[var(--color-bg)] border border-[var(--color-border)]">
      <h2 class="font-semibold mb-2 flex items-center gap-2">🔍 查找更多 Skills</h2>
      <code class="text-sm px-3 py-1.5 rounded-lg bg-[var(--color-surface)] border border-[var(--color-border)] inline-block font-mono">npx skills find [关键词]</code>
      <p class="text-sm text-[var(--color-text-secondary)] mt-2">例如：<code class="text-xs px-1.5 py-0.5 rounded bg-[var(--color-bg-secondary)] font-mono">npx skills find "react"</code>、<code class="text-xs px-1.5 py-0.5 rounded bg-[var(--color-bg-secondary)] font-mono">npx skills find "database"</code></p>
    </div>
    </main>

    <!-- Right-side TOC (desktop only) -->
    <aside id="page-toc" class="hidden xl:block w-56 shrink-0 sticky top-24 self-start max-h-[calc(100vh-8rem)] overflow-y-auto py-8 pr-4" aria-label="页面导航">
      <div class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-3">分类导航</div>
      <nav class="space-y-1">
        {skills.map((category, ci) => (
          <a href={`#skill-cat-${ci}`} class="block text-xs py-1 px-2 rounded text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/5 transition-colors duration-150">{category.category.replace(/\(\d+\)/, '').trim()}</a>
        ))}
      </nav>
    </aside>
  </div>
</BaseLayout>

<script>
  // Copy button handler
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.skill-copy-btn');
    if (!btn) return;

    const text = btn.getAttribute('data-copy');
    if (!text) return;

    navigator.clipboard.writeText(text).then(() => {
      const orig = btn.innerHTML;
      btn.innerHTML = '✅';
      btn.style.background = 'var(--color-success, #10B981)';
      btn.style.color = 'white';
      btn.style.borderColor = 'var(--color-success, #10B981)';
      setTimeout(() => {
        btn.innerHTML = orig;
        btn.style.background = '';
        btn.style.color = '';
        btn.style.borderColor = '';
      }, 1500);
    }).catch(() => {
      // Fallback: select text
      const codeEl = btn.parentElement?.querySelector('code');
      if (codeEl) {
        const range = document.createRange();
        range.selectNodeContents(codeEl);
        const selection = window.getSelection();
        selection?.removeAllRanges();
        selection?.addRange(range);
      }
    });
  });
</script>
