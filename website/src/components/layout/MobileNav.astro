---
// website/src/components/layout/MobileNav.astro
import { NAV_ITEMS, PHASES } from '@lib/constants';
---

<div id="mobile-sidebar" class="fixed inset-0 z-40 bg-[var(--color-bg)] flex-col hidden lg:invisible animate-fade-in-down">
  <div class="flex items-center justify-between p-4 border-b border-[var(--color-border)]">
    <span class="font-bold text-lg flex items-center gap-2">
      <span class="text-2xl">⚡</span>
      Vibe Coding 建站指南
    </span>
    <button id="close-mobile-nav" class="p-2 rounded-lg text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-secondary)] transition-colors" aria-label="关闭菜单">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  <nav class="flex-1 overflow-y-auto p-4">
    <div class="space-y-1 mb-6">
      {NAV_ITEMS.map((item) => (
        <a href={item.href}
          class="block px-3 py-2.5 rounded-lg text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)] hover:text-[var(--color-text)] transition-colors font-medium"
          onclick="document.getElementById('mobile-sidebar')?.classList.add('hidden')"
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="border-t border-[var(--color-border)] pt-4">
      <h3 class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-2 px-3">全流程实战</h3>
      <div class="space-y-0.5">
        {PHASES.map((phase) => (
          <a href={`/phases/${phase.id}`}
            class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)] hover:text-[var(--color-text)] transition-colors"
            onclick="document.getElementById('mobile-sidebar')?.classList.add('hidden')"
          >
            <span class="text-base">{phase.icon}</span>
            <span class="text-sm">{phase.title}</span>
          </a>
        ))}
      </div>
    </div>
  </nav>
</div>
