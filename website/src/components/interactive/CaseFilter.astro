---
// src/components/interactive/CaseFilter.astro
// Tag-style filter bar with client-side filtering — pure JS, no framework

interface CaseData {
  slug: string;
  difficulty: string;
  category: string;
  tech_type: string;
}

export interface Props {
  cases: CaseData[];
}

const { cases } = Astro.props;

const difficulties = [...new Set(cases.map(c => c.difficulty))] as string[];
const categories = [...new Set(cases.map(c => c.category))] as string[];
const techTypes = [...new Set(cases.map(c => c.tech_type))] as string[];

const filterGroups = [
  { label: '难度', items: difficulties, attr: 'difficulty' },
  { label: '类型', items: categories, attr: 'category' },
  { label: '技术', items: techTypes, attr: 'tech-type' },
];
---

<div id="case-filter" class="mb-6 flex flex-wrap items-center gap-2">
  {filterGroups.map((group) => (
    <div class="flex items-center gap-1 text-xs text-[var(--color-text-muted)]">
      {group.items.map((item, i) => (
        <button
          class="filter-btn px-2.5 py-1 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text-secondary)] hover:border-[var(--color-accent)]/30 hover:text-[var(--color-accent)] transition-colors duration-150 whitespace-nowrap"
          data-filter-attr={group.attr}
          data-filter-value={item}
        >{item}</button>
      ))}
    </div>
  ))}
</div>

<script>
  (function initFilter() {
    const container = document.getElementById('case-filter');
    if (!container) return;

    const cards = document.querySelectorAll('[data-case-card]');
    const cardData = [];
    cards.forEach(el => {
      cardData.push({
        el,
        attrValues: {
          difficulty: el.getAttribute('data-difficulty') || '',
          category: el.getAttribute('data-category') || '',
          'tech-type': el.getAttribute('data-tech-type') || '',
        },
      });
    });

    // Track active filters: key is attr name (difficulty/category/tech-type), value is filter value or null
    const activeFilters = {} as Record<string, string | null>;

    function filterCards() {
      const hasActiveFilter = Object.values(activeFilters).some(v => v !== null);

      // If no filters active, show all
      if (!hasActiveFilter) {
        cardData.forEach(({ el }) => el.classList.remove('filter-hidden'));
        const emptyState = document.getElementById('filter-empty-state');
        if (emptyState) emptyState.classList.add('hidden');
        return;
      }

      let anyVisible = false;
      cardData.forEach(({ el, attrValues }) => {
        let match = true;
        for (const key in activeFilters) {
          const val = activeFilters[key];
          if (val !== null && attrValues[key] !== val) {
            match = false;
            break;
          }
        }
        el.classList.toggle('filter-hidden', !match);
        if (match) anyVisible = true;
      });

      const emptyState = document.getElementById('filter-empty-state');
      if (emptyState) emptyState.classList.toggle('hidden', anyVisible);
    }

    container.addEventListener('click', (e) => {
      const btn = (e.target).closest('.filter-btn');
      if (!btn) return;

      const attr = btn.getAttribute('data-filter-attr');
      const value = btn.getAttribute('data-filter-value');
      if (!attr || !value) return;

      const groupParent = btn.parentElement;
      const siblings = groupParent.querySelectorAll('.filter-btn');

      // Toggle: if already active, deactivate; else activate this one
      if (btn.classList.contains('active')) {
        btn.classList.remove('active');
        activeFilters[attr] = null;
      } else {
        siblings.forEach(s => s.classList.remove('active'));
        btn.classList.add('active');
        activeFilters[attr] = value;
      }

      filterCards();
    });
  })();
</script>

<style>
  .filter-btn.active {
    background: var(--color-accent);
    color: white !important;
    border-color: var(--color-accent) !important;
  }
  .dark .filter-btn.active {
    background: var(--color-accent);
    color: white !important;
  }
  .filter-hidden {
    display: none !important;
  }
</style>
